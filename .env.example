# Copy to .env.local and adjust. Never put secrets in VITE_ variables:
# every VITE_ value is embedded in the public web bundle.

# Application identity (display only; canonical identity lives in
# src/shared/config/app-identity.constants.ts).
VITE_APP_NAME=Ultimate Natives
VITE_APP_ID=com.ultimatenatives.app

# API
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_API_MODE=mock
VITE_API_TIMEOUT_MS=15000

# Localization
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en,ar

# Theme: light | dark | system
VITE_DEFAULT_THEME=system

# Observability (leave empty to disable error reporting)
VITE_SENTRY_DSN=

# Realtime (NestJS Socket.IO gateway; leave empty to disable)
VITE_SOCKET_URL=

# Development tooling
VITE_ENABLE_QUERY_DEVTOOLS=true
