{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.eslint.tsbuildinfo",
    "types": ["vite/client", "node"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": [
    "src",
    "tests",
    "scripts",
    "eslint",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "capacitor.config.ts",
    "eslint.config.mjs",
    "commitlint.config.mjs"
  ]
}
