{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/tests",
    "tests/setup",
    "tests/factories",
    "tests/fixtures",
    "tests/mocks",
    "tests/unit",
    "tests/integration",
    "tests/contract",
    "tests/e2e",
    "tests/accessibility",
    "tests/visual",
    "tests/native"
  ]
}
